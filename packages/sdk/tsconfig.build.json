{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["node"],
    "composite": false,
    "incremental": false,
    "stripInternal": true
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts", "examples", "node_modules", "dist"]
}
