{
  "name": "fx-arcade-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "BUFX unified trading machine monorepo: web, API, Ponder, keepers, MCP, x402, and contract helpers.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "overrides": {
    "hono": "4.12.7",
    "wagmi": "2.14.11"
  },
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun run --filter ./apps/web dev",
    "dev:api": "bun run --filter ./apps/api dev",
    "dev:ponder": "bun run --filter ./apps/ponder dev",
    "keeper:gateway-signer": "bun run --filter ./apps/keeper-gateway-signer dev",
    "keeper:spot": "bun run --filter ./apps/keeper-spot dev",
    "keeper:perps-matcher": "bun run --filter ./apps/keeper-perps-matcher dev",
    "keeper:perps-liquidator": "bun run --filter ./apps/keeper-perps-liquidator dev",
    "keeper:perps-funding": "bun run --filter ./apps/keeper-perps-funding dev",
    "keeper:pyth": "bun run --filter ./apps/keeper-pyth dev",
    "keeper:arcade-settler": "bun run --filter ./apps/keeper-arcade-settler dev",
    "contracts:sync": "bun run scripts/sync-contracts.mjs",
    "smoke:perps-replacement:api": "bun scripts/perps-replacement-e2e-smoke.ts",
    "smoke:perps-replacement:browser": "bun scripts/perps-replacement-browser-e2e.ts",
    "smoke:perps-replacement:arc": "bun scripts/perps-live-arc-replacement-keeper-smoke.ts",
    "canary:perps-replacement:local": "bun scripts/perps-local-replacement-canary.ts",
    "canary:perps-replacement:arc": "bun scripts/perps-arc-replacement-canary.ts",
    "build": "bun run --filter ./apps/web build",
    "build:all": "bun run --filter '*' build",
    "lint": "bun run --filter ./apps/web lint",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "bun-types": "1.3.10",
    "typescript": "5"
  }
}
