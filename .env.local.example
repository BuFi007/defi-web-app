# ---------------------------------------------------------------------------
# Pyth EUR/USD keep-warm keeper (apps/keeper-pyth)
# ---------------------------------------------------------------------------
# Funded Arc Testnet EOA that signs Pyth.updatePriceFeeds() transactions.
# If unset, the keeper falls back to KEEPER_PRIVATE_KEY (the shared
# keeper signer used by every keeper-* app). Setting this lets you run
# the Pyth keeper with a dedicated key so balance accounting + nonce
# pressure stay isolated from the other keepers.
PYTH_KEEPER_PRIVATE_KEY=

# Pyth Hermes WS endpoint. The production URL is the default; override
# for staging / regional pinning.
# PYTH_HERMES_WS_URL=wss://hermes.pyth.network/ws

# Pyth proxy on Arc Testnet (matches apps/web/e2e/anvil-helpers/pyth-slots.json).
# PYTH_ARC_CONTRACT=0x2880aB155794e7179c9eE2e38200202908C17B43

# Comma-separated Pyth feed ids to keep warm. Default: EUR/USD + USDC/USD,
# which is what FxOracle.getMid(USDC, EURC) needs as a cross-rate.
# PYTH_FEED_IDS=0x76fa85158bf14ede77087fe3ae472f66213f6ea2f5b411cb2de472794990fa5c,0xeaa020c61cc479712813461ce153894a96a6c00b21ed0cfc2798d1f9a9e9c94a

# Minimum cadence between on-chain pushes, in milliseconds. The keeper
# also opportunistically pushes when a fresh Hermes WS tick arrives.
# PYTH_KEEP_WARM_INTERVAL_MS=30000

# Health endpoint port. GET http://localhost:9100/health.
# PYTH_KEEPER_HEALTH_PORT=9100

# ---------------------------------------------------------------------------
# Shared keeper signer (used by every apps/keeper-* if a per-keeper key
# is not set). Required for any on-chain keeper mutation.
# ---------------------------------------------------------------------------
KEEPER_PRIVATE_KEY=
