{
  "name": "@bufi/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Database contracts for BUFI backend services. Adapters: bun:sqlite (default), Postgres (scaffolded).",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./adapters/sqlite": "./src/adapters/sqlite.ts",
    "./adapters/postgres": "./src/adapters/postgres.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bufi/shared-types": "workspace:*"
  },
  "peerDependencies": {
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "bun-types": "1.3.10",
    "@types/node": "20",
    "@types/pg": "8",
    "typescript": "5"
  }
}
