{
  "name": "fx-arcade-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "BUFX unified trading machine monorepo: web, API, Ponder, Rust matcher keepers, MCP, x402, and contract helpers.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "overrides": {
    "hono": "4.12.18",
    "wagmi": "2.14.11",
    "@base-org/account": "2.5.6"
  },
  "packageManager": "bun@1.3.10",
  "scripts": {
    "setup": "bun install && bun run --filter @bufi/matcher build",
    "dev": "bun run --filter ./apps/web dev",
    "dev:api": "bun run --filter ./apps/api dev",
    "dev:ponder": "bun run --filter ./apps/ponder dev",
    "dev:core": "bun run --filter ./apps/web --filter ./apps/api --filter ./apps/ponder dev",
    "dev:complete": "bash scripts/dev-up.sh",
    "dev:complete:raw": "bun run --filter './apps/*' --filter './services/*' dev",
    "dev:up": "bash scripts/dev-up.sh",
    "dev:down": "bash scripts/dev-down.sh",
    "dev:logs": "tail -f /tmp/bufi-web.log /tmp/bufi-rest.log",
    "dev:complete:https": "BUFI_HTTPS=1 bash scripts/dev-up.sh",
    "matcher:dev": "bun run --filter @bufi/matcher dev",
    "matcher:build": "bun run --filter @bufi/matcher build",
    "matcher:test": "bun run --filter @bufi/matcher test",
    "matcher:test:audit-prep": "bun run --filter @bufi/matcher test:audit-prep",
    "matcher:clippy": "bun run --filter @bufi/matcher clippy",
    "matcher:smoke:live-arc": "bun run --filter @bufi/matcher smoke:live-arc",
    "keeper:gateway-signer": "bun run matcher:dev",
    "keeper:spot": "bun run matcher:dev",
    "keeper:perps-liquidator": "bun run matcher:dev",
    "keeper:telarana-liquidator": "bun run matcher:dev",
    "keeper:perps-matcher": "bun run matcher:dev",
    "keeper:perps-funding": "bun run matcher:dev",
    "keeper:arcade-settler": "bun run matcher:dev",
    "_comment_keeper_consolidation": "All keeper roles run inside services/matcher; legacy keeper:* scripts are matcher aliases.",
    "contracts:sync": "bun run scripts/sync-contracts.mjs",
    "smoke:perps-replacement:api": "bun scripts/perps-replacement-e2e-smoke.ts",
    "smoke:perps-replacement:browser": "bun scripts/perps-replacement-browser-e2e.ts",
    "smoke:perps-replacement:arc": "bun scripts/perps-live-arc-replacement-keeper-smoke.ts",
    "canary:perps-replacement:local": "bun scripts/perps-local-replacement-canary.ts",
    "canary:perps-replacement:arc": "bun scripts/perps-arc-replacement-canary.ts",
    "build": "bun run --filter ./apps/web build",
    "build:all": "bun run --filter '*' build",
    "lint": "bun run --filter ./apps/web lint",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "bun-types": "1.3.10",
    "concurrently": "^9.2.1",
    "typescript": "5"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.0.4",
    "connectkit": "^1.9.2"
  }
}
