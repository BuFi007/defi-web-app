# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
build/

# turbo / ponder
.turbo/
.ponder/
.ponder-user/
.bufi/
**/.bufi/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/
# .claude/ is per-developer scratch — ignore everything except the few
# directories we explicitly check in for team-shared tools.
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/circle-agent-wallet-to-mcp-dogfooding/

# External reference repos for matcher architecture (shallow clones, not deps)
references/

