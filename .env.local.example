# BUFI / FX Telaraña / BUFX — local dev env template.
#
# Copy to `.env.local` and fill in. The real `.env.local` is gitignored;
# this template is committed so contributors and demo scripts know
# which keys are wired up. No secrets in this file — only env-var
# names + the canonical "what does this point at" comment per key.
#
# ---------------------------------------------------------------------
# v4 swap routing — Wave M3
# ---------------------------------------------------------------------
#
# Universal Router would be the preferred entry point per the Uniswap
# v4 SDK (see ~/.claude/skills/v4-sdk-integration/SKILL.md), but it is
# NOT deployed on Arc Testnet — verified 2026-05-21 against
# https://developers.uniswap.org/contracts/v4/deployments. Until a
# Universal Router lands or fx-telarana Wave M3 broadcasts the
# canonical PoolSwapTest (from `@uniswap/v4-core/src/test/`) on Arc,
# demo scripts that route swaps from an EOA read the address from this
# env var. Once pinned in `@bufi/contracts/bento`
# (`getV4SwapRouterAddress(5042002)`), this fallback becomes a no-op.
#
# Arc Testnet (chainId 5042002) — used by L2 + L4 demo scripts to
# call `PoolManager.unlock` → inner `swap` against the FxSwapHook
# (0xC6F894f30d0D28972C876B4af58C02A4E88A0aC8) and
# TelaranaGatewayHubHook (0xe895CB461AFF6E98167a7FA0Db252ba906714088).
V4_SWAP_ROUTER_5042002=
# Avalanche Fuji (chainId 43113) — only set when an FX Bento PoolSwapTest
# lives on Fuji. Today, Fuji is the spoke side and no v4 swap is routed
# from an EOA there.
V4_SWAP_ROUTER_43113=

# Alternate name kept for compatibility with the fx-telarana scripts
# that hardcode `V4_SWAP_TEST_ROUTER` per the v4-periphery convention.
# Either of these is honored by @bufi/contracts; prefer the chain-id
# suffixed form above so multi-chain scripts don't collide.
V4_SWAP_TEST_ROUTER=

# ---------------------------------------------------------------------
# RPC overrides — @bufi/contracts/getRpcUrl()
# ---------------------------------------------------------------------
# Arc Testnet RPC override. Defaults to https://rpc.testnet.arc.network
# when unset. PublicNode + Alchemy mirrors are valid alternatives.
ARC_TESTNET_RPC_URL=
# Avalanche Fuji RPC override. Defaults to the PublicNode mirror.
AVALANCHE_FUJI_RPC_URL=

# ---------------------------------------------------------------------
# Demo keeper / broadcast keys — required by scripts/smoke-*.ts,
# never check real values in. The keeper EOA is
# 0x0646FFe11b9aBcE0054Ce6F73025F06F3E91eC69 — match the address, not
# this template comment.
# ---------------------------------------------------------------------
KEEPER_PRIVATE_KEY=
DEMO_MAKER_PRIVATE_KEY=
DEMO_TAKER_PRIVATE_KEY=

# ---------------------------------------------------------------------
# Circle Gateway attestation (Wave N2c)
# ---------------------------------------------------------------------
# Hex-encoded attestation payload + signature returned by the Circle
# Gateway /v1/transfer endpoint. `scripts/v4-swap-pool-demo-gateway.ts`
# reads these to drive a real on-chain v4 pool swap that mints USDC via
# `TelaranaGatewayHubHook.beforeSwap` atomically (no Iris polling).
#
# Mint flow: `apps/keeper-gateway-signer` -- run `bun run mint` from
# inside that app. The CLI signs an EIP-712 BurnIntent with
# KEEPER_PRIVATE_KEY, POSTs it to Circle's /v1/transfer endpoint, and
# persists the response at
# `apps/keeper-gateway-signer/attestations/<label>.json`. Copy the
# top-level `attestation` and `signature` fields from that artefact
# into the two vars below.
#
# Attestations have a TTL keyed to the source-chain block height
# (`expirationBlock` in the persisted artefact -- roughly ~24h on Fuji).
# Re-mint before that block to keep the demo broadcastable.
V4_SWAP_GATEWAY_ATTESTATION=
V4_SWAP_GATEWAY_SIGNATURE=

# ---------------------------------------------------------------------
# Gateway attestation rotation keeper (Wave N7c)
# ---------------------------------------------------------------------
# `apps/keeper-gateway-signer/src/index.ts` runs as a long-lived keeper
# that re-mints attestations BEFORE their on-chain TTL expires. Without
# this, the demo path breaks every ~24h because the attestation embedded
# in V4_SWAP_GATEWAY_ATTESTATION above goes stale. The keeper writes the
# fresh attestation back to `apps/keeper-gateway-signer/attestations/`,
# and the operator re-exports V4_SWAP_GATEWAY_* from the latest artefact
# whenever the broadcast tool runs.
#
# All four vars below are optional — sensible defaults are baked in. The
# only one production deploys MUST set is GATEWAY_KEEPER_PRIVATE_KEY (or
# rely on the KEEPER_PRIVATE_KEY fallback).
#
# When unset, the keeper boots, prints "dry-run mode; would rotate <N>
# attestations on next tick" and exits 0.
GATEWAY_KEEPER_PRIVATE_KEY=
# Default 9101. Exposes /health (JSON snapshot of tracked attestations,
# next rotation ETA, last tx id, current Fuji block).
GATEWAY_KEEPER_HEALTH_PORT=
# Default 10800 (~6h at 2s Fuji block time). Re-mint when an attestation's
# `expirationBlock - currentFujiBlock` drops below this.
GATEWAY_ROTATION_BUFFER_BLOCKS=
# Default 300000 (5 min). Tick cadence. Two-minute slack against the
# rotation buffer (~6h - 5m).
GATEWAY_KEEPER_INTERVAL_MS=
# Default 3600000 (1h). Minimum wall-clock gap between re-mints of the
# SAME label — caps fee burn if the block-clock comparison drifts (see
# README "Block-clock caveat" section).
GATEWAY_KEEPER_MIN_REMINT_MS=
